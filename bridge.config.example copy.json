{
  "feishu": {
    "app_id": "cli_xxx",
    "app_secret": "xxxxxx",
    "mode": "ws",
    "port": 18080,
    "callback_url": "https://your-domain.example",
    "encrypt_key": "",
    "verification_token": "replace-with-feishu-verification-token",
    "signing_secret": "replace-with-feishu-signing-secret"
  },
  "codex": {
    "runtime": "app-server",
    "binary_path": "codex",
    "model": null,
    "cwd": ".",
    "sandbox_mode": "workspace-write",
    "approval_policy": "on-request",
    "workspace_roots": [
      ".",
      "../shared"
    ],
    "allow_free_cwd": false,
    "network_access": false,
    "web_search": false
  },
  "security": {
    "allowed_sender_ids": [],
    "enable_trusted_senders": false,
    "enable_host_danger_tools": false
  },
  "workspaces": [
    {
      "id": "main",
      "name": "Main Workspace",
      "cwd": ".",
      "additional_directories": [
        "../shared"
      ],
      "default_model": null,
      "web_search": false
    }
  ],
  "host_control": {
    "enabled": true,
    "provider": "auto",
    "allowed_tools": [
      "host.get_status",
      "host.open_url",
      "host.open_app",
      "host.capture_screen",
      "host.list_windows",
      "host.focus_window",
      "host.read_clipboard",
      "host.write_clipboard",
      "host.notify"
    ],
    "danger_tools": [
      "host.keypress",
      "host.mouse",
      "host.shutdown",
      "host.reboot",
      "host.sleep"
    ]
  },
  "actions": [
    {
      "name": "git-status",
      "command": [
        "git",
        "status",
        "--short"
      ],
      "cwd": ".",
      "require_approval": false,
      "allow_network": false
    },
    {
      "name": "test",
      "command": [
        "bun",
        "run",
        "test"
      ],
      "cwd": ".",
      "require_approval": true,
      "allow_network": false
    }
  ],
  "storage": {
    "database_path": "./data/bridge.db",
    "files_dir": "./data/files",
    "log_file": "./logs/bridge.log"
  }
}
