{
  "name": "message-bridge-codex-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Feishu mobile remote console for Codex hosts",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "message-bridge-codex": "dist/src/bin/bridge-daemon.js"
  },
  "scripts": {
    "dev": "bun run src/bin/bridge-daemon.ts",
    "start": "node dist/src/bin/bridge-daemon.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/*.test.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "mcp",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.8"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.39.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex-sdk": "^0.114.0",
    "marked": "^16.3.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.8",
    "typescript": "^5.8.3"
  }
}
